{
  "name": "fekt",
  "private": true,
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm store prune",
    "lint:staged": "nano-staged",
    "prepare": "husky install",
    "release:tskit": "pnpm -C packages/tskit run release"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "nano-staged": "^1.0.2",
    "prettier": "^3.8.2",
    "tsdown": "0.21.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "nano-staged": {
    "*.{js,ts,json,md,mjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "pnpm": ">= 10.33.0"
  }
}
