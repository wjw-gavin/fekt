{
  "name": "fekt",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "pnpm store prune",
    "lint:staged": "nano-staged",
    "prepare": "husky install",
    "release:tskit": "pnpm -C packages/tskit run release"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.7",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "nano-staged": "^1.0.2",
    "prettier": "^3.8.3",
    "tsdown": "0.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.7"
  },
  "nano-staged": {
    "*.{js,ts,json,md,mjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "pnpm": ">= 11.5.1"
  }
}
